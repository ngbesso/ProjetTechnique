# --- PostgreSQL ---
POSTGRES_USER=obnl
POSTGRES_PASSWORD=changeme
POSTGRES_DB=obnl
DATABASE_URL=postgresql+psycopg://obnl:changeme@postgres:5432/obnl

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (stockage objet S3-compatible) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=sermons

# --- Sécurité ---
# Générez une clé : python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Administrateur par défaut (seed au démarrage) ---
ADMIN_EMAIL=admin@obnl.org
ADMIN_PASSWORD=Admin1234!

# --- Service IA ---
AI_SERVICE_URL=http://ai-service:8001
BACKEND_URL=http://backend:8000
# Clé API Anthropic (https://console.anthropic.com/) — requise pour le chatbot RAG
LLM_API_KEY=

# --- Dons (Zeffy) ---
# Chemin d'embed : depuis le code Zeffy, copier la valeur de data-form-url
# Exemple : /embed/donation-form/soutenez-notre-mission-603
VITE_ZEFFY_EMBED_PATH=/embed/donation-form/VOTRE-SLUG

# Secret partagé pour valider les webhooks Zeffy (choisissez une chaîne aléatoire)
# À configurer dans Zeffy : Paramètres > Intégrations > Webhook URL :
#   https://votre-domaine.com/api/donations/webhooks/zeffy?secret=VOTRE_SECRET
ZEFFY_WEBHOOK_SECRET=

VITE_AI_SERVICE_URL=http://localhost:8001
